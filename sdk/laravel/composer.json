{
    "name": "croncontrol/laravel-sdk",
    "description": "CronControl SDK for Laravel - scheduled jobs, queues, and heartbeat reporting",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0|^11.0|^12.0",
        "guzzlehttp/guzzle": "^7.0"
    },
    "autoload": {
        "psr-4": {
            "CronControl\\Laravel\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "CronControl\\Laravel\\CronControlServiceProvider"
            ],
            "aliases": {
                "CronControl": "CronControl\\Laravel\\Facades\\CronControl"
            }
        }
    },
    "minimum-stability": "stable"
}
