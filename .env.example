# CronControl Environment Variables

# Core
CC_DB_URL=postgres://croncontrol:croncontrol@localhost:5435/croncontrol?sslmode=disable
CC_PORT=8080
CC_LOG_LEVEL=info
CC_MODE=selfhosted  # saas or selfhosted
CC_BASE_URL=http://localhost:8080

# Scheduling
CC_PLANNER_INTERVAL=1h
CC_PLANNER_HORIZON=24h
CC_EXECUTOR_INTERVAL=30s
CC_MONITOR_INTERVAL=30s

# Concurrency
CC_MAX_CONCURRENT=50
CC_MAX_CONCURRENT_LOCAL=10
CC_MAX_CONCURRENT_HTTP=20
CC_MAX_CONCURRENT_SSH=5
CC_MAX_CONCURRENT_SSM=10
CC_MAX_CONCURRENT_K8S=20

# Auth
CC_GOOGLE_CLIENT_ID=
CC_GOOGLE_CLIENT_SECRET=
CC_GOOGLE_ALLOWED_DOMAIN=
CC_SESSION_SECRET=change-me-in-production
CC_ENCRYPTION_KEY=change-me-32-bytes-for-aes256!!

# Alerts
CC_WEBHOOK_URL=

# Retention
CC_RETENTION_SLOTS=30d
CC_RETENTION_OUTPUT=30d
CC_RETENTION_HEARTBEATS=30d
CC_RETENTION_JOBS=30d
CC_RETENTION_JOB_ATTEMPTS=30d
CC_RETENTION_AUDIT=90d
CC_CLEANUP_SCHEDULE=03:00
CC_CLEANUP_BATCH_SIZE=1000

# Logging Backend
CC_LOG_BACKEND=database  # database, file, or opensearch
CC_LOG_FILE_PATH=./logs/
CC_LOG_FILE_MAX_SIZE=100MB
CC_LOG_FILE_MAX_AGE=30d
CC_LOG_OPENSEARCH_URL=http://localhost:9200
CC_LOG_OPENSEARCH_PREFIX=croncontrol
CC_LOG_OPENSEARCH_AUTH=none  # none, basic, apikey

# AWS (for SSM target)
CC_AWS_PROFILE=

# K8s (for K8s target)
CC_K8S_KUBECONFIG=

# SaaS
CC_REGISTRATION_ENABLED=true
CC_DISPOSABLE_EMAIL_CHECK=true
