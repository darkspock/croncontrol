---
// Orchestra animation — interactive. Director hub + "Musicians" orbiting.
// Hover any node to see a popup describing what it does.
---

<div class="relative w-full h-full">
  <canvas id="orchestra-network" class="absolute inset-0 w-full h-full"></canvas>
  <div id="orchestra-tooltip" class="fixed z-50 pointer-events-none opacity-0 transition-opacity duration-150 px-3 py-2 rounded-lg border border-indigo-500/20 bg-[#0c0c10]/95 backdrop-blur-sm shadow-xl shadow-black/40 max-w-52" style="transform: translate(-50%, -100%) translateY(-12px);">
    <p id="tt-role" class="text-[10px] font-mono font-semibold text-indigo-400 uppercase tracking-wider mb-0.5"></p>
    <p id="tt-name" class="text-xs font-semibold text-white mb-1"></p>
    <p id="tt-desc" class="text-[11px] text-zinc-400 leading-relaxed"></p>
    <p id="tt-status" class="text-[10px] font-mono mt-1.5 flex items-center gap-1.5"></p>
  </div>
</div>

<script>
  const canvas = document.getElementById('orchestra-network') as HTMLCanvasElement;
  const tooltip = document.getElementById('orchestra-tooltip') as HTMLDivElement;
  const ttRole = document.getElementById('tt-role')!;
  const ttName = document.getElementById('tt-name')!;
  const ttDesc = document.getElementById('tt-desc')!;
  const ttStatus = document.getElementById('tt-status')!;
  if (!canvas) throw new Error('canvas not found');
  const ctx = canvas.getContext('2d')!;

  let W = 0, H = 0;
  const DPR = Math.min(window.devicePixelRatio || 1, 2);

  function resize() {
    const rect = canvas.parentElement!.getBoundingClientRect();
    W = rect.width;
    H = rect.height;
    canvas.width = W * DPR;
    canvas.height = H * DPR;
    canvas.style.width = W + 'px';
    canvas.style.height = H + 'px';
    ctx.setTransform(DPR, 0, 0, DPR, 0, 0);
    layoutNodes();
  }

  // --- Node info for tooltips ---
  const nodeInfo = [
    { role: 'Director', name: 'AI Director', desc: 'Reads the full score, decides the next worker to execute, or asks a human for input.', status: '●  Coordinating 3 active movements', statusColor: '#818cf8' },
    { role: 'AgentNode', name: 'Data Scraper', desc: 'Fetches product data from external APIs and returns structured JSON results.', status: '●  Running — 67% progress', statusColor: '#34d399' },
    { role: 'AgentNode', name: 'Validator', desc: 'Checks scraped data for anomalies, duplicates, and schema compliance.', status: '●  Idle — waiting for directive', statusColor: '#a1a1aa' },
    { role: 'AgentNode', name: 'Transform Pipeline', desc: 'Normalizes, enriches, and transforms data for downstream consumers.', status: '●  Running — 42% progress', statusColor: '#34d399' },
    { role: 'AgentNode', name: 'Notifier', desc: 'Sends Slack messages, emails, or webhook calls when conditions are met.', status: '●  Idle — 12 notifications sent', statusColor: '#a1a1aa' },
    { role: 'AgentNode', name: 'Database Writer', desc: 'Upserts validated records into PostgreSQL with conflict resolution.', status: '●  Running — 890/1200 rows', statusColor: '#34d399' },
    { role: 'AgentNode', name: 'Report Generator', desc: 'Creates PDF/CSV summaries and uploads them as run artifacts.', status: '●  Idle — last report 2m ago', statusColor: '#a1a1aa' },
    { role: 'AgentNode', name: 'Cleanup', desc: 'Archives old records, deletes expired data, frees storage.', status: '●  Scheduled — next run in 4m', statusColor: '#fbbf24' },
    { role: 'AgentNode', name: 'Health Checker', desc: 'Pings external services, verifies SSL certs, checks DNS.', status: '●  Running — 8/10 checks passed', statusColor: '#34d399' },
    { role: 'AgentNode', name: 'ML Inference', desc: 'Runs anomaly detection model on incoming data batches.', status: '●  Idle — GPU container standby', statusColor: '#a1a1aa' },
  ];

  // --- Nodes ---
  interface OrchestraNode {
    x: number; y: number;
    baseR: number; r: number;
    phase: number; speed: number;
    hue: number; sat: number; light: number;
    pulsePhase: number;
    role: 'director' | 'musician';
    orbitAngle: number;
    orbitRadius: number;
    orbitSpeed: number;
    idx: number;
  }

  const MUSICIAN_COUNT = 9;
  const nodes: OrchestraNode[] = [];

  const musicianColors = [
    { h: 200, s: 75, l: 55 }, { h: 160, s: 60, l: 50 }, { h: 270, s: 60, l: 55 },
    { h: 220, s: 80, l: 60 }, { h: 320, s: 55, l: 55 }, { h: 180, s: 65, l: 50 },
    { h: 250, s: 70, l: 58 }, { h: 140, s: 55, l: 48 }, { h: 30, s: 60, l: 55 },
  ];

  function layoutNodes() {
    nodes.length = 0;
    const cx = W / 2, cy = H / 2;
    const orbitR = Math.min(W, H) * 0.32;

    nodes.push({
      x: cx, y: cy, baseR: 38, r: 38, phase: 0, speed: 0.004,
      hue: 235, sat: 85, light: 65, pulsePhase: 0, role: 'director',
      orbitAngle: 0, orbitRadius: 0, orbitSpeed: 0, idx: 0,
    });

    for (let i = 0; i < MUSICIAN_COUNT; i++) {
      const angle = (i / MUSICIAN_COUNT) * Math.PI * 2 - Math.PI / 2;
      const p = musicianColors[i % musicianColors.length];
      const rV = 0.88 + Math.random() * 0.24;
      nodes.push({
        x: cx + Math.cos(angle) * orbitR * rV,
        y: cy + Math.sin(angle) * orbitR * rV,
        baseR: 16 + Math.random() * 8, r: 0, phase: Math.random() * Math.PI * 2,
        speed: 0.005 + Math.random() * 0.003,
        hue: p.h, sat: p.s, light: p.l, pulsePhase: Math.random() * Math.PI * 2,
        role: 'musician', orbitAngle: angle, orbitRadius: orbitR * rV,
        orbitSpeed: 0.0003 + Math.random() * 0.0004, idx: i + 1,
      });
    }
  }
  layoutNodes();

  // --- Hover ---
  let hoveredIdx = -1;
  let mouseX = 0, mouseY = 0;

  canvas.addEventListener('mousemove', (e) => {
    const rect = canvas.getBoundingClientRect();
    const mx = e.clientX - rect.left;
    const my = e.clientY - rect.top;
    mouseX = e.clientX;
    mouseY = e.clientY;

    let found = -1;
    for (let i = nodes.length - 1; i >= 0; i--) {
      const n = nodes[i];
      const hitR = n.r * 1.8;
      if (Math.hypot(mx - n.x, my - n.y) < hitR) { found = i; break; }
    }

    if (found !== hoveredIdx) {
      hoveredIdx = found;
      if (found >= 0) {
        canvas.style.cursor = 'pointer';
        const info = nodeInfo[found];
        ttRole.textContent = info.role;
        ttName.textContent = info.name;
        ttDesc.textContent = info.desc;
        ttStatus.innerHTML = `<span style="color:${info.statusColor}">${info.status}</span>`;
        tooltip.style.opacity = '1';
      } else {
        canvas.style.cursor = 'default';
        tooltip.style.opacity = '0';
      }
    }

    if (hoveredIdx >= 0) {
      tooltip.style.left = mouseX + 'px';
      tooltip.style.top = mouseY + 'px';
    }
  });

  canvas.addEventListener('mouseleave', () => {
    hoveredIdx = -1;
    canvas.style.cursor = 'default';
    tooltip.style.opacity = '0';
  });

  // --- Packets ---
  interface Packet {
    from: number; to: number; t: number; speed: number; hue: number;
    cx: number; cy: number; type: 'directive' | 'result' | 'lateral';
  }
  const packets: Packet[] = [];
  let nextD = 0, nextR = 0, nextL = 0;

  function bezCtrl(a: OrchestraNode, b: OrchestraNode, pull: number) {
    const mx = (a.x + b.x) / 2, my = (a.y + b.y) / 2;
    const dist = Math.hypot(b.x - a.x, b.y - a.y);
    const off = dist * pull * (Math.random() > 0.5 ? 1 : -1);
    const ang = Math.atan2(b.y - a.y, b.x - a.x) + Math.PI / 2;
    return { cx: mx + Math.cos(ang) * off, cy: my + Math.sin(ang) * off };
  }

  function spawnPackets(now: number) {
    if (now > nextD) {
      nextD = now + 250 + Math.random() * 350;
      const to = 1 + Math.floor(Math.random() * MUSICIAN_COUNT);
      const c = bezCtrl(nodes[0], nodes[to], 0.15);
      packets.push({ from: 0, to, t: 0, speed: 0.012 + Math.random() * 0.006, hue: 235, ...c, type: 'directive' });
    }
    if (now > nextR) {
      nextR = now + 400 + Math.random() * 500;
      const from = 1 + Math.floor(Math.random() * MUSICIAN_COUNT);
      const c = bezCtrl(nodes[from], nodes[0], 0.15);
      packets.push({ from, to: 0, t: 0, speed: 0.01 + Math.random() * 0.005, hue: nodes[from].hue, ...c, type: 'result' });
    }
    if (now > nextL) {
      nextL = now + 600 + Math.random() * 700;
      const from = 1 + Math.floor(Math.random() * MUSICIAN_COUNT);
      let to = 1 + Math.floor(Math.random() * (MUSICIAN_COUNT - 1));
      if (to >= from) to++;
      if (to > MUSICIAN_COUNT) to = 1;
      const a = nodes[from], b = nodes[to];
      const mx = (a.x + b.x) / 2, my = (a.y + b.y) / 2;
      packets.push({ from, to, t: 0, speed: 0.008 + Math.random() * 0.004, hue: a.hue,
        cx: mx + (nodes[0].x - mx) * 0.3, cy: my + (nodes[0].y - my) * 0.3, type: 'lateral' });
    }
  }

  function quadBez(ax: number, ay: number, cx: number, cy: number, bx: number, by: number, t: number) {
    const u = 1 - t;
    return { x: u*u*ax + 2*u*t*cx + t*t*bx, y: u*u*ay + 2*u*t*cy + t*t*by };
  }

  // --- Draw ---
  function draw(now: number) {
    ctx.clearRect(0, 0, W, H);
    const cx = W / 2, cy = H / 2;

    // Update positions
    for (let i = 1; i <= MUSICIAN_COUNT; i++) {
      const n = nodes[i];
      n.orbitAngle += n.orbitSpeed;
      n.x = cx + Math.cos(n.orbitAngle) * n.orbitRadius;
      n.y = cy + Math.sin(n.orbitAngle) * n.orbitRadius;
    }
    for (const n of nodes) {
      n.phase += n.speed;
      n.r = n.baseR + Math.sin(n.phase) * n.baseR * 0.2;
      n.pulsePhase += 0.02;
    }

    // Connections
    const d = nodes[0];
    for (let i = 1; i <= MUSICIAN_COUNT; i++) {
      const m = nodes[i];
      const isHovered = hoveredIdx === 0 || hoveredIdx === i;
      ctx.beginPath(); ctx.moveTo(d.x, d.y); ctx.lineTo(m.x, m.y);
      ctx.strokeStyle = `hsla(235, 60%, 60%, ${isHovered ? 0.15 : 0.05})`;
      ctx.lineWidth = isHovered ? 1.5 : 0.8; ctx.stroke();
    }
    for (let i = 1; i <= MUSICIAN_COUNT; i++) {
      const next = i < MUSICIAN_COUNT ? i + 1 : 1;
      ctx.beginPath(); ctx.moveTo(nodes[i].x, nodes[i].y); ctx.lineTo(nodes[next].x, nodes[next].y);
      ctx.strokeStyle = `hsla(200, 40%, 50%, 0.03)`; ctx.lineWidth = 0.5; ctx.stroke();
    }

    // Nodes
    for (const n of nodes) {
      const pulse = 0.5 + 0.5 * Math.sin(n.pulsePhase);
      const isDir = n.role === 'director';
      const isHov = hoveredIdx === n.idx;
      const glowR = n.r * (isDir ? 3.0 : 2.2);
      const alphaBoost = isHov ? 1.6 : 1;
      const cAlpha = (isDir ? 0.18 + pulse * 0.08 : 0.10 + pulse * 0.05) * alphaBoost;

      const grd = ctx.createRadialGradient(n.x, n.y, 0, n.x, n.y, glowR);
      grd.addColorStop(0, `hsla(${n.hue}, ${n.sat}%, ${n.light}%, ${cAlpha})`);
      grd.addColorStop(0.4, `hsla(${n.hue}, ${n.sat}%, ${n.light}%, ${cAlpha * 0.5})`);
      grd.addColorStop(1, `hsla(${n.hue}, ${n.sat}%, ${n.light}%, 0)`);
      ctx.beginPath(); ctx.arc(n.x, n.y, glowR, 0, Math.PI * 2); ctx.fillStyle = grd; ctx.fill();

      const core = ctx.createRadialGradient(n.x, n.y, 0, n.x, n.y, n.r * 0.5);
      core.addColorStop(0, `hsla(${n.hue}, ${n.sat}%, ${n.light + 15}%, ${(0.3 + pulse * 0.12) * alphaBoost})`);
      core.addColorStop(1, `hsla(${n.hue}, ${n.sat}%, ${n.light}%, 0)`);
      ctx.beginPath(); ctx.arc(n.x, n.y, n.r * 0.5, 0, Math.PI * 2); ctx.fillStyle = core; ctx.fill();

      if (isDir) {
        ctx.beginPath(); ctx.arc(n.x, n.y, n.r * 0.9, 0, Math.PI * 2);
        ctx.strokeStyle = `hsla(${n.hue}, ${n.sat}%, ${n.light}%, ${(0.08 + pulse * 0.04) * alphaBoost})`;
        ctx.lineWidth = 1.5; ctx.stroke();
      }

      // Hover ring
      if (isHov) {
        ctx.beginPath(); ctx.arc(n.x, n.y, n.r * 1.3, 0, Math.PI * 2);
        ctx.strokeStyle = `hsla(${n.hue}, ${n.sat}%, ${n.light + 20}%, 0.3)`;
        ctx.lineWidth = 1; ctx.setLineDash([3, 3]); ctx.stroke(); ctx.setLineDash([]);
      }
    }

    // Packets
    spawnPackets(now);
    for (let i = packets.length - 1; i >= 0; i--) {
      const p = packets[i];
      p.t += p.speed;
      if (p.t >= 1) { nodes[p.to].pulsePhase = 0; packets.splice(i, 1); continue; }
      const a = nodes[p.from], b = nodes[p.to];
      const pos = quadBez(a.x, a.y, p.cx, p.cy, b.x, b.y, p.t);
      const tLen = p.type === 'directive' ? 8 : 5;
      const bAlpha = p.type === 'directive' ? 0.7 : 0.5;
      const bRad = p.type === 'directive' ? 3.5 : 2.5;
      for (let s = 0; s < tLen; s++) {
        const tt = Math.max(0, p.t - s * 0.012);
        const tp = quadBez(a.x, a.y, p.cx, p.cy, b.x, b.y, tt);
        ctx.beginPath(); ctx.arc(tp.x, tp.y, Math.max(0.5, bRad - s * 0.3), 0, Math.PI * 2);
        ctx.fillStyle = `hsla(${p.hue}, 80%, 70%, ${(1 - s / tLen) * bAlpha})`; ctx.fill();
      }
      const glow = ctx.createRadialGradient(pos.x, pos.y, 0, pos.x, pos.y, p.type === 'directive' ? 14 : 10);
      glow.addColorStop(0, `hsla(${p.hue}, 90%, 80%, 0.5)`);
      glow.addColorStop(1, `hsla(${p.hue}, 90%, 80%, 0)`);
      ctx.beginPath(); ctx.arc(pos.x, pos.y, p.type === 'directive' ? 14 : 10, 0, Math.PI * 2);
      ctx.fillStyle = glow; ctx.fill();
    }

    requestAnimationFrame(draw);
  }

  requestAnimationFrame(draw);

  let resizeTimer: ReturnType<typeof setTimeout>;
  window.addEventListener('resize', () => { clearTimeout(resizeTimer); resizeTimer = setTimeout(resize, 200); });
  resize();
</script>
